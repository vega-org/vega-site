---
const features = [
  {
    icon: "live_tv",
    title: "Free Streaming",
    description:
      "Stream without subscription lock-ins, with full control over your media setup.",
  },
  {
    icon: "shield_lock",
    title: "Privacy Focused",
    description: "No trackers. Vega is local-first and transparent.",
  },
  {
    icon: "gavel",
    title: "Apache-2.0 License",
    description: "Built on a permissive license suitable for all use cases.",
  },
  {
    icon: "source",
    title: "Bring Your Own Sources",
    description:
      "Connect your own providers and catalogs while keeping your stack flexible and portable.",
  },
  {
    icon: "download",
    title: "Offline Downloading",
    description:
      "Save content for offline playback so your library stays available anywhere.",
  },
  {
    icon: "forum",
    title: "Community",
    description:
      "Join discord for any questions, feedback, or to connect with other users and contributors.",
  },
];
---

<section class="bg-vega-bg-soft px-4 py-24 md:px-6" id="features">
  <div class="mx-auto w-full max-w-350">
    <h2
      class="font-headline text-[clamp(2rem,4vw,3.2rem)] font-black tracking-tight text-white"
    >
      Features
    </h2>
    <div class="mt-3 h-1 w-24 bg-vega-accent" aria-hidden="true"></div>

    <div class="mt-12 grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
      {
        features.map((feature) => (
          <article class="rounded-2xl border border-white/8 bg-vega-surface-hi p-8 transition hover:-translate-y-0.5 hover:border-vega-accent/35">
            <span
              class="material-symbols-outlined mb-5 text-4xl text-vega-accent"
              aria-hidden="true"
            >
              {feature.icon}
            </span>
            <h3 class="font-headline text-2xl font-bold text-white">
              {feature.title}
            </h3>
            <p class="mt-3 leading-relaxed text-vega-muted">
              {feature.description}
            </p>
          </article>
        ))
      }
    </div>
  </div>
</section>
