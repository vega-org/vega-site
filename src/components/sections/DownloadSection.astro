---
import { REPO, DESKTOP_REPO } from "../../config/site";
import PlatformDownload from "./PlatformDownload.astro";
---

<section class="bg-vega-bg px-4 py-24 md:px-6" id="download">
  <div class="mx-auto w-full max-w-5xl text-center">
    <h2
      class="font-headline text-[clamp(2rem,4vw,3.2rem)] font-black tracking-tight text-white"
    >
      Ready to ascend?
    </h2>
    <p class="mx-auto mt-4 max-w-3xl text-lg text-vega-muted">
      Grab the latest stable build of Vega.
    </p>

    <div class="mt-12 flex flex-col gap-12">
      <PlatformDownload repo={REPO} title="Vega for Android" id="android" />
      <PlatformDownload
        repo={DESKTOP_REPO}
        title="Vega for Desktop"
        autoDetectOS={true}
        id="desktop"
      />
    </div>
  </div>
</section>
